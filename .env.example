# Copy this file to .env and change every sensitive value before running Docker Compose

# Postgres
POSTGRES_USER=superset
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=superset

# Superset secret (generate a long random value)
SUPERSET_SECRET_KEY=change_this_to_a_long_random_secret_key

# Initial admin account
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_FIRSTNAME=Admin
SUPERSET_ADMIN_LASTNAME=User
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=change_this_admin_password
